{
  "name": "ztoolbox",
  "version": "0.1.0",
  "description": "A toolbox Electron application",
  "packageManager": "yarn@4.15.0",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "NODE_OPTIONS=\"--enable-source-maps\" yarn electron .",
    "start-win": "set NODE_OPTIONS=\"--enable-source-maps\" && yarn electron .",
    "pre-build": "tsc --project tsconfig-scripts.json",
    "build": "yarn pre-build && yarn gulp",
    "pack": "yarn pre-build && yarn gulp build && DO_PACK=1 yarn node scripts/build.js",
    "dist": "yarn pre-build && yarn gulp build && yarn node scripts/build.js",
    "postinstall": "tsc --project tsconfig-scripts.json && node scripts/postinstall.js",
    "ts-watch": "tsc --watch"
  },
  "repository": "git@github.com:ZatsuneSakurako/ztoolbox-app.git",
  "keywords": [
    "Electron"
  ],
  "author": {
    "name": "Zatsune Sakurako",
    "url": "https://linktr.ee/zatsune_sakurako"
  },
  "os": [
    "linux",
    "win32"
  ],
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@types/gulp": "^4.0.18",
    "@types/gulp-sass": "^6.0.0",
    "@types/ini": "^4.1.1",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^24.12.4",
    "@types/nunjucks": "^3.2.6",
    "@types/pug": "^2.0.10",
    "@types/requirejs": "^2.1.37",
    "@types/sanitize-html": "^2",
    "@types/sass": "^1.45.0",
    "@types/shelljs": "^0.10.0",
    "@types/ws": "^8.18.1",
    "del": "^8.0.1",
    "electron": "^42.2.0",
    "electron-builder": "26.11.1",
    "gulp": "^5.0.1",
    "gulp-cli": "^3.1.0",
    "gulp-pug": "^5.0.0",
    "pug": "^3.0.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fontsource/ubuntu": "^5.2.8",
    "@jimp/core": "^1.6.1",
    "@jimp/js-png": "^1.6.1",
    "@jimp/plugin-print": "^1.6.1",
    "@jimp/plugin-resize": "^1.6.1",
    "cron-parser": "^5.5.0",
    "fastify": "^5.8.5",
    "i18next": "^26.2.0",
    "ini": "^7.0.0",
    "json5": "^2.2.3",
    "lodash.debounce": "^4.0.8",
    "marked": "^18.0.5",
    "material-symbols": "^0.44.8",
    "monaco-editor": "^0.55.1",
    "nunjucks": "^3.2.4",
    "protocol-registry": "^2.0.0",
    "requirejs": "^2.3.8",
    "sanitize-html": "^2.17.5",
    "shelljs": "^0.10.0",
    "simple-git": "^3.36.0",
    "socket.io": "^4.8.3",
    "ws": "^8.20.1",
    "yaml": "^2.9.0"
  }
}
